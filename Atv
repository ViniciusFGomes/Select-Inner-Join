1 SELECT products.ProductName,suppliers.SupplierName,suppliers.Country
FROM products
inner JOIN suppliers ON
products.SupplierID = suppliers.SupplierID
WHERE CategoryID = 2

2 SELECT orders.OrderID,
orders.OrderDate,
shippers.ShipperName
FROM orders
INNER JOIN shippers
ON orders.shipperID = shippers.shipperID

3 SELECT products.ProductName,suppliers.City
FROM products
INNER JOIN suppliers
ON products.SupplierID = suppliers.SupplierID
WHERE Price > 50

4 SELECT orders.OrderID, shippers.ShipperName
FROM orders
INNER JOIN shippers
ON orders.ShipperID= shippers.ShipperID
WHERE ShipperName LIKE '%Speedy Express%'

5 SELECT products.ProductName, suppliers.SupplierName
FROM products
INNER JOIN suppliers
ON products.SupplierID= suppliers.SupplierID
WHERE Country = 'Brazil' OR Country = 'USA'

6 SELECT shippers.Phone,
orders.OrderDate,
orders.OrderID
FROM shippers
INNER JOIN orders 
ON shippers.ShipperID = orders.ShipperID
WHERE OrderDate LIKE '2023%'

7 SELECT products.ProductName, suppliers.SupplierName
FROM products
INNER JOIN suppliers
ON products.SupplierID= suppliers.SupplierID
WHERE Price BETWEEN 10 AND 20

8 SELECT orders.OrderID, shippers.ShipperName
FROM orders
INNER JOIN shippers
ON orders.ShipperID = shippers.ShipperID
order by ShipperName ASC

9 SELECT products.ProductName, suppliers.SupplierName
FROM products
LEFT JOIN suppliers
ON products.SupplierID = suppliers.SupplierID

10 SELECT orders.OrderID, shippers.ShipperName
FROM orders
LEFT JOIN shippers
ON orders.ShipperID = shippers.ShipperID

11 SELECT suppliers.SupplierName, products.ProductName
FROM suppliers
RIGHT JOIN products ON products.SupplierID = suppliers.SupplierID	

12 SELECT suppliers.SupplierName, products.ProductName
FROM suppliers
LEFT JOIN products ON products.ProductID = suppliers.SupplierID
WHERE City = 'GERMANY'

13 SELECT shippers.ShipperName, orders.OrderID
FROM orders
RIGHT JOIN shippers ON orders.OrderID = shippers.ShipperID

14 SELECT products.ProductName, suppliers.SupplierName, shippers.ShipperName, orders.OrderID
FROM suppliers
INNER JOIN products ON Products.SupplierID = suppliers.SupplierID
INNER JOIN orderdetails ON orderdetails.ProductID = products.ProductID
INNER JOIN orders ON orders.OrderID	= orderdetails.OrderID
INNER JOIN shippers ON orders.ShipperID = shippers.ShipperID

15 SELECT suppliers.SupplierName,suppliers.City,orders.OrderDate, shippers.ShipperName
FROM suppliers
INNER JOIN products ON Products.SupplierID = suppliers.SupplierID
INNER JOIN orderdetails ON orderdetails.ProductID = products.ProductID
INNER JOIN orders ON orders.OrderID	= orderdetails.OrderID
INNER JOIN shippers ON orders.ShipperID = shippers.ShipperID	
WHERE ShipperName = 'United Package';

16 SELECT DISTINCT suppliers.SupplierName
FROM Suppliers 
INNER JOIN Products ON products.SupplierID = suppliers.SupplierID
LEFT JOIN OrderDetails ON orderdetails.ProductID = products.ProductID
WHERE OrderID IS NULL;

17 SELECT suppliers.ContactName,products.ProductName
FROM Suppliers
INNER JOIN Products ON products.SupplierID = suppliers.SupplierID
WHERE Country = 'UK'
AND CategoryID IN (1, 3, 5);

18 SELECT suppliers.SupplierName,COUNT(DISTINCT orders.OrderID) AS TotalPedidos
FROM Suppliers
INNER JOIN Products ON products.SupplierID = suppliers.SupplierID
INNER JOIN OrderDetails ON orderdetails.ProductID = products.ProductID
INNER JOIN Orders ON orders.OrderID = orderdetails.OrderID
GROUP BY SupplierName;

19 SELECT products.ProductName,categories.CategoryName,suppliers.SupplierName
FROM Products
INNER JOIN Categories ON categories.CategoryID = products.CategoryID
INNER JOIN Suppliers ON suppliers.SupplierID = products.SupplierID
WHERE products.Price > (
SELECT AVG(Price)
FROM Products
);

20 SELECT orders.OrderID,suppliers.SupplierName,shippers.ShipperName
FROM Orders
INNER JOIN OrderDetails ON orderdetails.OrderID = orders.OrderID
INNER JOIN Products ON products.ProductID = orderdetails.ProductID
INNER JOIN Suppliers ON suppliers.SupplierID = products.SupplierID
INNER JOIN Shippers ON shippers.ShipperID = orders.ShipperID;



